{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/refs/heads/main/cli/schemas/config-file.v1.json",
  "fmt": {
    "proseWrap": "preserve"
  },
  "lint": {
    "rules": { "tags": ["recommended"] }
  },
  "exclude": ["coverage/", "testdata/"],
  "imports": {
    "@std/assert": "jsr:@std/assert@1.0.19"
  },
  "tasks": {
    "check": "deno run --allow-read check-readability.ts",
    "lint": "deno lint && deno check && deno fmt --check",
    "fix": "deno lint --fix && deno fmt",
    "test": "deno test -A --parallel --shuffle --coverage"
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  }
}
